{
    "name": "suat-namdar/php-app-mvc",
    "description": "Mini MVC skeleton with auth, RBAC, CSRF, and admin panel",
    "type": "project",
    "require": {
        "php": "^8.2",
        "nikic/fast-route": "^1.3",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
